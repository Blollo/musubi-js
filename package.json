{
    "name": "musubi-js",
    "version": "0.1.1",
    "description": "Vue-Composition-API-style reactivity and DOM bindings for traditional multi-page sites. No build step required.",
    "type": "module",
    "main": "./dist/musubi.js",
    "module": "./dist/musubi.js",
    "types": "./dist/types/index.d.ts",
    "unpkg": "./dist/musubi.iife.min.js",
    "jsdelivr": "./dist/musubi.iife.min.js",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "default": "./dist/musubi.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "sideEffects": false,
    "scripts": {
        "dev": "vite",
        "build": "vite build && tsc -p tsconfig.build.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "pack:check": "npm pack --dry-run",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "npm run build && changeset publish"
    },
    "keywords": [
        "reactive",
        "reactivity",
        "dom",
        "bindings",
        "directives",
        "mpa",
        "vue",
        "composition-api",
        "no-build"
    ],
    "author": "Alessio Giusti",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Blollo/musubi-js.git"
    },
    "homepage": "https://github.com/Blollo/musubi-js#readme",
    "bugs": {
        "url": "https://github.com/Blollo/musubi-js/issues"
    },
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@vitest/coverage-v8": "^4.1.8",
        "eslint": "^10.4.1",
        "jsdom": "^29.1.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16",
        "vitest": "^4.1.8"
    }
}
